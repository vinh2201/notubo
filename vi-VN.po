msgid "changelog_140"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1. Một video hỗ trợ hoạt ảnh vào/ra/kết hợp cùng lúc\n"
"2. Hỗ trợ tài liệu trượt chuột xem trước nhanh"
	
msgid "changelog_160"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1. Khả năng bánh xe màu trực tuyến để hỗ trợ độ chính xác cao hơn\n"
"2. Hỗ trợ loại bỏ nhấp nháy và giảm nhiễu video để cải thiện chất lượng video của bạn\n"
"3. Hỗ trợ cắt tùy chỉnh thông minh, cho phép cắt nhanh bằng một cú nhấp chuột\n"
"4. Hỗ trợ thêm các vật phẩm làm đẹp và điều chỉnh hình thể để làm phong phú nội dung màn hình\n"
"5. Hỗ trợ xuất file phụ đề\n"
"6. Hỗ trợ cấu hình kênh trái và phải"
	
msgid "changelog_200"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1. Không gian đám mây trực tuyến, hỗ trợ khả năng tương tác dự thảo trên thiết bị di động và máy tính để bàn\n"
"2. Đã thêm hỗ trợ cho phụ đề thông minh tiếng Ý, tiếng Pháp, tiếng Thổ Nhĩ Kỳ, tiếng Trung, tiếng Hà Lan, tiếng Việt, tiếng Thái, tiếng Mã Lai, tiếng Rumani\n"
"3. Ra mắt "Chia ống kính thông minh", hỗ trợ phân tách nhanh chóng các clip dòng thời gian và bảng vật liệu thành phim hoàn chỉnh, giúp việc chỉnh sửa phụ hiệu quả hơn\n"
"4. Khắc phục sự cố cắt khung và sai khung đã biết\n"
"5. Khắc phục sự cố lớp phủ chuyển tiếp sẽ làm thay đổi thời lượng của các video clip\n"
"6. Thư viện tài liệu trong nước hỗ trợ hủy tài liệu nhập và xóa tài liệu"
	
msgid "changelog_205"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1. Hỗ trợ chuyển động tự do của khung phím, kiểm soát tham số độc lập của khung phím và khả năng đường cong khung phím chuyên nghiệp"
	
msgid "changelog_230"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1.Hỗ trợ tiếng Séc, tiếng Hà Lan, tiếng Phần Lan, tiếng Hy Lạp, tiếng Hungary, tiếng Ba Lan, tiếng Rumani, tiếng Thụy Điển\n"
"2. Đã thêm hỗ trợ tiện ích chuyển đổi quy mô thông minh để giúp bạn luôn giữ nhân vật ở vị trí tốt nhất theo các tỷ lệ khác nhau\n"
"3.Hỗ trợ kéo các hộp văn bản để ngắt dòng nhanh\n"
"4. Tối ưu hóa khả năng điều chỉnh độ sáng và độ bão hòa của bánh xe màu\n"
"5. Video mới phong cách 3D, chỉ cần một cú nhấp chuột là có được hiệu ứng tuyệt vời"
	
msgid "changelog_PC120"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1. Hỗ trợ theo dõi chuyển động, giúp tạo hiệu ứng tiếp theo dễ dàng hơn\n"
"2. Bản nhạc phụ hỗ trợ thêm phần chuyển tiếp và thêm hiệu ứng một cách tự do hơn\n"
"3. Đã thêm mô-đun hiệu ứng đặc biệt cho nhân vật, nhiều hiệu ứng nhân vật hơn đang chờ bạn sử dụng"
	
msgid "changelog_PC130"
msgstr ""
"Nâng cấp chức năng giúp bạn dễ dàng tạo dựng cuộc sống tốt đẹp hơn~\n"
"1. Khả năng chỉnh sửa văn bản phong phú hơn\n"
"2. Đã thêm mô-đun làm đẹp mới để dễ dàng áp dụng nhiều hiệu ứng trang điểm\n"
"3. Hỗ trợ xuất các tập tin âm thanh thuần túy ở định dạng mp3, wav và các định dạng khác\n"
"4. Hỗ trợ căn chỉnh các tài liệu video và âm thanh, giúp việc chỉnh sửa nhiều camera hiệu quả hơn"
	
msgid "changlog_150"
